# ========================
# Large / generated data
# ========================

# PMTiles (generated by Planetiler) — re-generate with scripts
pmtiles/
boundaries/*.pmtiles
boundaries/*.pmtiles.bak

# OSM source data (downloaded from Geofabrik) — re-download with setup.ps1
osm-data/

# GADM boundary data (downloaded) — re-download with download-gadm.ps1
gadm/*.json
gadm/states/

# Large GeoJSON boundary files (generated by split-boundaries.js)
boundaries/*.geojson

# Planetiler JAR + data dependencies
planetiler.jar
natural_earth_vector.sqlite.zip
tile_weights.tsv.gz
data/

# Martin tile server binary
tileserver/martin.exe


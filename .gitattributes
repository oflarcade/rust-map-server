# Auto detect text files and normalize line endings
* text=auto

# Scripts - keep LF on all platforms for Docker compatibility
*.sh text eol=lf
*.py text eol=lf
*.js text eol=lf

# PowerShell - CRLF (Windows native)
*.ps1 text eol=crlf

# Config files
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.conf text eol=lf
*.md text eol=lf
*.html text eol=lf

# Docker
Dockerfile* text eol=lf
docker-compose*.yml text eol=lf

# Binary files - never diff
*.pmtiles binary
*.osm.pbf binary
*.jar binary
*.exe binary
*.zip binary
*.gz binary
*.geojson binary
